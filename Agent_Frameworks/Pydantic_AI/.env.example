# Pydantic AI Research Multi-Agent System — Environment Variables
# Copy this file to .env and fill in your API key

# Required
OPENAI_API_KEY=sk-...

# Per-agent model selection (optional — these are the defaults)
SUPERVISOR_MODEL=gpt-4o-mini
RESEARCHER_MODEL=gpt-4o-mini
ANALYST_MODEL=gpt-4o
WRITER_MODEL=gpt-4o
CRITIC_MODEL=gpt-4o-mini

# Research behavior
MAX_REVISIONS=2
RESEARCH_DEPTH=standard
