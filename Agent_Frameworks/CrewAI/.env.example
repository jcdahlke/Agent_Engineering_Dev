# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional: Serper (Google Search via SerperDevTool) ────────────────────────
# Get a free key at https://serper.dev
# If left empty, SerperDevTool is skipped; WebsiteSearchTool + arxiv are used.
SERPER_API_KEY=your_serper_api_key_here

# ── Agent model selection ─────────────────────────────────────────────────────
RESEARCHER_MODEL=gpt-4o-mini
ANALYST_MODEL=gpt-4o-mini
WRITER_MODEL=gpt-4o
EDITOR_MODEL=gpt-4o-mini
MANAGER_MODEL=gpt-4o

# ── Crew tuning ───────────────────────────────────────────────────────────────
MAX_RPM=10
MEMORY_DIR=.crew_memory
VERBOSE=true
