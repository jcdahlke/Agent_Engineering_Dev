# ─────────────────────────────────────────────────────────────────────────────
#  OpenAI Agent SDK — Advanced Research Multi-Agent System
#  Copy this file: cp .env.example .env
#  Then fill in your OpenAI API key below.
# ─────────────────────────────────────────────────────────────────────────────

# Required: get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Per-agent model selection ─────────────────────────────────────────────────
# Cheaper models (gpt-4o-mini) for routing/validation; stronger for synthesis
SUPERVISOR_MODEL=gpt-4o-mini
RESEARCHER_MODEL=gpt-4o-mini
ANALYST_MODEL=gpt-4o
WRITER_MODEL=gpt-4o
CRITIC_MODEL=gpt-4o-mini
GUARDRAIL_MODEL=gpt-4o-mini

# ── Research behavior ─────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_REVISIONS=2
RESEARCH_DEPTH=standard
# Each tool call + each LLM response counts as one turn; 5-agent pipeline needs ~20-50
MAX_TURNS=50
